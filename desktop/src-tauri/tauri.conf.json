{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Airouter",
  "version": "0.1.0",
  "identifier": "local.airouter.desktop",
  "build": {
    "beforeDevCommand": "node scripts/prepare-frontend.mjs && node scripts/prepare-resources.mjs && node scripts/prepare-node.mjs",
    "beforeBuildCommand": "node scripts/prepare-frontend.mjs && node scripts/prepare-resources.mjs && node scripts/prepare-node.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Airouter",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": ["resources/airouter"],
    "externalBin": ["binaries/node"],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  }
}
