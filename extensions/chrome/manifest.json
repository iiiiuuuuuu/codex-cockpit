{
  "manifest_version": 3,
  "name": "ai-cockpit 控制台",
  "description": "从 Chrome 工具栏查看 ai-cockpit 状态、打开管理页、刷新额度和查看日志。",
  "version": "0.1.0",
  "key": "",
  "action": {
    "default_title": "ai-cockpit",
    "default_popup": "popup.html"
  },
  "permissions": [
    "clipboardWrite",
    "nativeMessaging",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ]
}
